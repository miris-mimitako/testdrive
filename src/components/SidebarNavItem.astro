---
interface Props {
  href: string;
  icon: string;
  label: string;
  active?: boolean;
}

const { href, icon, label, active = false } = Astro.props;
const className = active
  ? 'flex items-center gap-3 bg-white text-slate-900 rounded-lg shadow-sm px-4 py-2.5 mb-1 font-sans text-[13px] font-semibold uppercase tracking-wider'
  : 'flex items-center gap-3 text-slate-500 px-4 py-2.5 mb-1 hover:bg-slate-200/50 rounded-lg transition-all font-sans text-[13px] font-semibold uppercase tracking-wider';
---

<a class={className} href={href}>
  <span class="material-symbols-outlined text-xl">{icon}</span>
  <span>{label}</span>
</a>
