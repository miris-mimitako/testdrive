---
import ApiHealthCard from './ApiHealthCard.astro';
import InfoTile from './InfoTile.astro';

interface Props {
  apiHealth: {
    endpoint: string;
    status: string;
    timestamp: string;
    message: string;
    ok: boolean;
  };
}

const { apiHealth } = Astro.props;
---

<section>
  <div id="overview" class="mb-10 flex items-end justify-between gap-4">
    <div>
      <h2 class="text-3xl font-extrabold text-on-surface tracking-tight mb-2">ホーム画面</h2>
      <p class="text-on-surface-variant font-medium">静的な UI サンプルを起点に、将来の Astro / NestJS 構成へ育てていくためのトップページです。</p>
    </div>
    <div class="flex gap-3">
      <div class="px-4 py-2 bg-white rounded-lg shadow-sm border border-slate-100 flex items-center gap-2">
        <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
        <span class="text-xs font-bold text-on-surface-variant">FULLSTACK PROTOTYPE READY</span>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
    <div class="md:col-span-2 bg-surface-container-lowest rounded-lg p-8 shadow-[0px_12px_32px_rgba(42,52,57,0.04)] flex flex-col justify-between group hover:shadow-[0px_12px_48px_rgba(42,52,57,0.08)] transition-all duration-300">
      <div class="flex justify-between items-start">
        <div class="w-14 h-14 bg-primary-container rounded-xl flex items-center justify-center text-primary mb-6">
          <span class="material-symbols-outlined text-3xl">home_app_logo</span>
        </div>
        <span class="material-symbols-outlined text-on-surface-variant/20 group-hover:text-primary transition-colors">north_east</span>
      </div>
      <div>
        <h3 class="text-xl font-bold text-on-surface mb-2">Astro + NestJS の土台を確認する</h3>
        <p class="text-on-surface-variant leading-relaxed max-w-md">Astro のホーム画面から NestJS の `/api/health` を実際に表示し、フロントと API の疎通を確認できる状態にしました。</p>
        <div class="mt-6 flex items-center gap-4 flex-wrap">
          <button class="bg-primary text-white px-6 py-2.5 rounded font-bold text-sm tracking-wide">npm run start</button>
          <span class="text-xs font-bold text-on-surface-variant uppercase tracking-widest opacity-60">固定ポートで同時起動</span>
        </div>
      </div>
    </div>

    <ApiHealthCard {...apiHealth} />

    <InfoTile icon="draw" title="UI サンプル調整" description="日本語化と文言の最適化" tone="emerald" />
    <InfoTile icon="description" title="設計メモ整理" description="docs と AGENTS の整合を維持" tone="blue" />
    <InfoTile icon="rocket_launch" title="API 疎通確認" description="Astro から /api/health を表示" tone="purple" />
  </div>
</section>
