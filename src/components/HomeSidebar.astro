---
import SidebarNavItem from './SidebarNavItem.astro';
---

<aside class="h-screen w-64 fixed left-0 top-0 flex flex-col bg-slate-100 z-50">
  <div class="p-6">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center text-white">
        <span class="material-symbols-outlined">dashboard</span>
      </div>
      <div>
        <h1 class="text-lg font-black text-slate-800 leading-tight">testdrive</h1>
        <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant opacity-70">UI SAMPLE WORKSPACE</p>
      </div>
    </div>
    <nav class="flex flex-col space-y-1">
      <SidebarNavItem href="#" icon="home" label="ホーム" active />
      <SidebarNavItem href="#overview" icon="dashboard" label="概要" />
      <SidebarNavItem href="#workflow" icon="alt_route" label="進め方" />
      <SidebarNavItem href="#migration" icon="conversion_path" label="Astro化" />
    </nav>
  </div>
  <div class="mt-auto p-6 space-y-4">
    <button class="w-full bg-primary text-white py-3 rounded-lg font-bold text-sm flex items-center justify-center gap-2 hover:bg-primary-dim transition-colors shadow-lg shadow-primary/10">
      <span class="material-symbols-outlined text-lg">edit_square</span>
      ホーム画面を編集
    </button>
    <div class="pt-4 flex flex-col space-y-1 border-t border-slate-200/50">
      <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-slate-200/50 rounded-lg transition-all font-sans text-[13px] font-semibold uppercase tracking-wider" href="/_docs/ui_design_sample/dashboard.html">
        <span class="material-symbols-outlined text-xl">description</span>
        <span>元サンプル</span>
      </a>
      <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-slate-200/50 rounded-lg transition-all font-sans text-[13px] font-semibold uppercase tracking-wider" href="/AGENTS.md">
        <span class="material-symbols-outlined text-xl">smart_toy</span>
        <span>AGENTS</span>
      </a>
    </div>
  </div>
</aside>
